{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/open-source-builder-kit/manifest.schema.json",
  "title": "Open Source Builder Kit Manifest",
  "type": "object",
  "required": ["name", "repository", "description"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "license": {
      "type": "string"
    },
    "maintainers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    }
  },
  "additionalProperties": true
}

